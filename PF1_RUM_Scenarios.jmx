              <BeanShellPreProcessor guiclass="TestBeanGUI" testclass="BeanShellPreProcessor" testname="BeanShell PreProcessor">
                <boolProp name="resetInterpreter">false</boolProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="script">String patientIds = &quot;&quot;;

int count= Integer.parseInt(vars.get(&quot;C_Active_PatientsIds_matchNr&quot;));

for (int i=1;i&lt;=15;i++)
{
	patientIds=patientIds+vars.get(&quot;C_Active_PatientsIds_&quot;+i);
	if(i&lt;15)
	patientIds=patientIds+&quot;,&quot;;

}

vars.put(&quot;C_patientIds15&quot;,patientIds);
</stringProp>
