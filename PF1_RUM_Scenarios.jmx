              <stringProp name="script">import java.io.*;
import java.util.Date;
import java.text.SimpleDateFormat;

responseBytes = prev.getResponseData();
sizeInBytes = responseBytes.length;
sizeInMB = ((double) sizeInBytes) / (1024 * 1024);
sizeInKB = ((double) sizeInBytes) / 1024;

double roundedMB = Math.round(sizeInMB * 100.0) / 100.0;
double roundedKB = Math.round(sizeInKB * 100.0) / 100.0;

if(&quot;200&quot;.equals(prev.getResponseCode()))
{
	String filePath = &quot;${SuccessPath}Pass_SC07_Pwd_ReportGen_14days_T03_14DRepgen_${datetimeVar}.csv&quot;;
     File file = new File(filePath);
    try {
        synchronized (this) { // Ensure thread-safe writing
            boolean writeHeader = !file.exists();
            BufferedWriter writer = new BufferedWriter(new FileWriter(file, true));
            if (writeHeader) {
                writer.write(&quot;ClinicWorkerID,begDate,Enddate,PDFSizeInMB,PDFSizeInKB\n&quot;);
            }
            writer.write(&quot;${SC07_ClinicalWorkerId_g1}&quot; + &quot;,&quot; + &quot;${SC07_ClinicalWorkerId_g2}&quot; + &quot;,&quot; + &quot;${SC07_ClinicalWorkerId_g3}&quot; + &quot;,&quot; + roundedMB + &quot;,&quot; + roundedKB + &quot;\n&quot;);          
            writer.close();
        }
    } catch (IOException e) {
        log.error(&quot;Error writing to file: &quot; + e.getMessage());
    }
}</stringProp>
