        <hashTree>
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.time.LocalDate
import java.time.temporal.ChronoUnit
import java.time.temporal.TemporalAdjusters
import java.time.DayOfWeek

// Get today&apos;s date
def today = LocalDate.now()

// Calculate the date 12 weeks ago
def twelveWeeksAgo = today.minusWeeks(12)

// Find the Sunday of that specific week (assuming Sunday is the start/end of the week)
// TemporalAdjusters.previousOrSame(DayOfWeek.SUNDAY) finds the Sunday on or immediately before the date.
def sundayOfThatWeek = twelveWeeksAgo.with(TemporalAdjusters.previousOrSame(DayOfWeek.SUNDAY))

def targetDate = sundayOfThatWeek.plusDays(6)

// Format the date as needed (e.g., &quot;yyyy-MM-dd&quot;)
def formattedDate = sundayOfThatWeek.format(java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;))

def formattedDate1 = targetDate.format(java.time.format.DateTimeFormatter.ofPattern(&quot;yyyy-MM-dd&quot;))

// Store the date in a JMeter variable (e.g., &quot;TargetSundayDate&quot;)
vars.put(&quot;TargetSundayDate&quot;, formattedDate)
vars.put(&quot;6days&quot;, formattedDate1)

// Log the result for debugging purposes (optional)
log.info(&quot;Date 12 weeks ago: &quot; + twelveWeeksAgo.toString())
log.info(&quot;Sunday of that week: &quot; + formattedDate)
log.info(&quot;6days of that week: &quot; + formattedDate1)
</stringProp>
          </JSR223PreProcessor>
