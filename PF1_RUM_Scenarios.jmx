              <stringProp name="script">import java.io.*;
import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.TimeZone;

// Format date
String formatDate(long millis, String format, String timezone) {
    SimpleDateFormat sdf = new SimpleDateFormat(format);
    sdf.setTimeZone(TimeZone.getTimeZone(timezone));
    return sdf.format(new Date(millis));
}

// Collect variables
String code = prev.getResponseCode();
if (!code.equals(&quot;200&quot;) &amp;&amp; !code.equals(&quot;304&quot;)) {
    String formattedDate = formatDate(ctx.getPreviousResult().getStartTime(), &quot;yyyy-MM-dd HH:mm:ss&quot;, &quot;US/Eastern&quot;);
    vars.put(&quot;startTime&quot;, formattedDate);

    // Use a fixed filename
    String filePath = &quot;${FailurePath}Fail_SC08_GUI_HCP_Pending_Staff_T03_PendingStaff${datetimeVar}.csv&quot;;
    File file = new File(filePath);

    String[] data = {formattedDate,code,prev.getResponseMessage(),ctx.getCurrentSampler().toString(),ctx.getCurrentSampler().getMethod().toString(),vars.get(&quot;SC08_TenantId&quot;),vars.get(&quot;C_Clinic_Id&quot;)};

    try {
        synchronized (this) { // Ensure thread-safe writing
            boolean writeHeader = !file.exists();
            BufferedWriter writer = new BufferedWriter(new FileWriter(file, true));
            if (writeHeader) {
                writer.write(&quot;SampleStartTime,ErrorCode,ResponseMessage,RequestUrl,Method,userID,ClinicID\n&quot;);
            }
            writer.write(String.join(&quot;,&quot;, data) + &quot;\n&quot;);
            writer.close();
        }
    } catch (IOException e) {
        log.error(&quot;Error writing to file: &quot; + e.getMessage());
    }
}</stringProp>
