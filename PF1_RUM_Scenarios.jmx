            <hashTree/>
            <BeanShellPostProcessor guiclass="TestBeanGUI" testclass="BeanShellPostProcessor" testname="ErrorLogs_File">
              <boolProp name="resetInterpreter">false</boolProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="script">import java.io.*;
import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.TimeZone;

// Format date
String formatDate(long millis, String format, String timezone) {
    SimpleDateFormat sdf = new SimpleDateFormat(format);
    sdf.setTimeZone(TimeZone.getTimeZone(timezone));
    return sdf.format(new Date(millis));
}

// Collect variables
String code = prev.getResponseCode();
if (!code.equals(&quot;200&quot;) &amp;&amp; !code.equals(&quot;304&quot;)) {
    String formattedDate = formatDate(ctx.getPreviousResult().getStartTime(), &quot;yyyy-MM-dd HH:mm:ss&quot;, &quot;US/Eastern&quot;);
    vars.put(&quot;startTime&quot;, formattedDate);

    // Use a fixed filename
    String filePath = &quot;${FailurePath}Fail_SC08_Pwd_Previous_Insights_T02_Login_${datetimeVar}.csv&quot;;
    File file = new File(filePath);

    String[] data = {formattedDate,code,prev.getResponseMessage(),ctx.getCurrentSampler().toString(),ctx.getCurrentSampler().getMethod().toString(),vars.get(&quot;SC08_ClinicalWorkerId_g1&quot;)};

    try {
        synchronized (this) { // Ensure thread-safe writing
            boolean writeHeader = !file.exists();
            BufferedWriter writer = new BufferedWriter(new FileWriter(file, true));
            if (writeHeader) {
                writer.write(&quot;SampleStartTime,ErrorCode,ResponseMessage,RequestUrl,Method,userID\n&quot;);
            }
            writer.write(String.join(&quot;,&quot;, data) + &quot;\n&quot;);
            writer.close();
        }
    } catch (IOException e) {
        log.error(&quot;Error writing to file: &quot; + e.getMessage());
    }
}</stringProp>
            </BeanShellPostProcessor>
            <hashTree/>
            <BeanShellPostProcessor guiclass="TestBeanGUI" testclass="BeanShellPostProcessor" testname="SuccessLog_File">
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <boolProp name="resetInterpreter">false</boolProp>
              <stringProp name="script">import java.io.*;
import java.util.Date;
import java.text.SimpleDateFormat;


if(&quot;200&quot;.equals(prev.getResponseCode()))
{
	String filePath = &quot;${SuccessPath}Pass_SC08_Pwd_Previous_Insights_T02_Login_${datetimeVar}.csv&quot;;
     File file = new File(filePath);
    try {
        synchronized (this) { // Ensure thread-safe writing
            boolean writeHeader = !file.exists();
            BufferedWriter writer = new BufferedWriter(new FileWriter(file, true));
            if (writeHeader) {
                writer.write(&quot;CustomerId,begDate,Enddate\n&quot;);
            }
           writer.write(&quot;${SC08_ClinicalWorkerId_g1}&quot;+&quot;,&quot; + &quot;${SC08_ClinicalWorkerId_g2}&quot; + &quot;,&quot; + &quot;${SC08_ClinicalWorkerId_g3}&quot; + &quot;\n&quot;);
           writer.close();
        }
    } catch (IOException e) {
        log.error(&quot;Error writing to file: &quot; + e.getMessage());
    }
}</stringProp>
            </BeanShellPostProcessor>
