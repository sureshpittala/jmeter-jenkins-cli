              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import java.util.Random

int count = vars.get(&apos;C_Active_PatientsIds_matchNr&apos;) as int
if (count &gt; 0) {
    int randomIndex = 1 + new Random().nextInt(count)
    String picked = vars.get(&apos;C_Active_PatientsIds_&apos; + randomIndex)
    vars.put(&apos;patientId_random&apos;, picked)
}

// Use vars.get(...) to read JMeter variables
log.info(&quot;activePatientID=&quot; + vars.get(&apos;patientId_random&apos;))
</stringProp>
